{
  "lint": {
    "exclude": [
      "static/*/*.min.*"
    ]
  },
  "fmt": {
    "exclude": [
      "static/*/*.min.*"
    ]
  },
  "imports": {
    "@deno/esbuild-plugin": "jsr:@deno/esbuild-plugin@^1.2.1",
    "@types/react": "npm:@types/react@^19.2.14",
    "@types/react-dom": "npm:@types/react-dom@^19.2.3",
    "@codemirror/autocomplete": "npm:@codemirror/autocomplete@^6.20.2",
    "@codemirror/lang-python": "npm:@codemirror/lang-python@^6.2.1",
    "@codemirror/lint": "npm:@codemirror/lint@^6.9.6",
    "@codemirror/state": "npm:@codemirror/state@^6.6.0",
    "@codemirror/view": "npm:@codemirror/view@^6.42.1",
    "@uiw/react-codemirror": "npm:@uiw/react-codemirror@^4.25.9",
    "chart.js": "npm:chart.js@^4.5.1",
    "esbuild": "npm:esbuild@^0.28.0",
    "react": "npm:react@^19.2.6",
    "react-chartjs-2": "npm:react-chartjs-2@^5.3.1",
    "react-dom": "npm:react-dom@^19.2.6"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "strict": true,
    "lib": [
      "dom",
      "dom.iterable",
      "dom.asynciterable",
      "deno.ns",
      "deno.unstable"
    ],
    "types": ["@types/react", "@types/react-dom"]
  }
}
